\name{compare_eqc_spc}
\alias{compare_eqc_spc}
\title{Deprecated Alias for EQC/SAC Comparison}
\usage{
compare_eqc_spc(...)
}
\arguments{
\item{...}{Arguments passed to \code{compare_eqc_sac()}.}
}
\value{
The result of \code{\link{compare_eqc_sac}}.
}
